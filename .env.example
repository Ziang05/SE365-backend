# Biến môi trường cho CafeF Crawler Backend
# Copy file này thành .env rồi điền giá trị thực

# CORS: danh sách origins được phép gọi API, phân cách bằng dấu phẩy
# Ví dụ production: ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Thư mục lưu file CSV/JSONL output
DATA_DIR=./data/raw

# Cổng server (chỉ dùng khi chạy bằng script, uvicorn dùng --port)
PORT=8000
